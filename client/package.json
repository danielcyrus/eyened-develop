    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.4.1",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.0.0",
    "unimported": "^1.31.0",
    "unplugin-icons": "^22.1.0",
    "vite": "^6.2.5",
    "vite-plugin-glsl": "^1.4.0"
  },
  "dependencies": {
    "@cornerstonejs/dicom-image-loader": "^3.7.8",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@types/json-schema": "^7.0.15",
